# ── DigitalOcean Gradient AI ──────────────────────────────────────────
DO_API_TOKEN=your_digitalocean_api_token
GRADIENT_MODEL=anthropic/claude-sonnet-4-20250514

# Optional: if using managed Gradient agents instead of serverless inference
GRADIENT_AGENT_PREP_ID=
GRADIENT_AGENT_COACH_ID=
GRADIENT_AGENT_PROXY_ID=
GRADIENT_KB_ID=

# ── Deepgram (real-time speech-to-text for Mode 2) ───────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key

# ── Twilio (outbound calls for Mode 3) ───────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# ── App Settings ─────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./phoneangel.db
DEBUG=true
